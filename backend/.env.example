# Copy this to .env and fill in your values

APP_NAME=Orbis
APP_ENV=development
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://orbis_user:orbis_secret@localhost:5432/orbis_db
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_ACQUIRE_TIMEOUT_SECS=3

REDIS_URL=redis://:orbis_redis_secret@localhost:6379

JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

RESEND_API_KEY=re_YOUR_KEY_HERE
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com
EMAIL_FROM_NAME=Orbis CRM

STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
REQUEST_TIMEOUT_SECS=30

RATE_LIMIT_PER_MINUTE_UNAUTH=100
RATE_LIMIT_PER_MINUTE_AUTH=300

RUST_LOG=orbis=debug,tower_http=debug,sqlx=warn
