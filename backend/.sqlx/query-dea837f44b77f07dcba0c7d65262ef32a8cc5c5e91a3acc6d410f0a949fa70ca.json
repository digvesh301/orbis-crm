{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.first_name, u.last_name, u.email, u.org_id,\n               u.avatar_url, u.is_email_verified, o.name as org_name\n        FROM users u\n        JOIN organizations o ON o.id = u.org_id\n        WHERE u.id = $1 AND u.deleted_at IS NULL\n        ",
